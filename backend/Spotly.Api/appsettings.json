{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Booking": {
    "CheckInCutoffUtc": "09:30"
  },
  "Database": {
    "Provider": "InMemory",
    "Name": "spotly-poc"
  },
  "RestaurantMessaging": {
    "Provider": "TelegramMock",
    "PollingIntervalMinutes": 10
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "Cors": {
    "AllowedOrigins": ["https://spotly.azurewebsites.net"]
  }
}
