{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Site": {
    "TimeZoneId": "Europe/Rome"
  },
  "Booking": {
    "CheckInOpenLocal": "07:00",
    "CheckInCloseLocal": "09:30"
  },
  "Lunch": {
    "ServiceStartLocal": "11:00",
    "ServiceEndLocal": "15:00"
  },
  "Database": {
    "Provider": "InMemory",
    "Name": "spotly-poc"
  },
  "RestaurantMessaging": {
    "Provider": "TelegramMock",
    "PollingIntervalMinutes": 10,
    "PartnerTimeoutSeconds": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "Cors": {
    "AllowedOrigins": ["https://spotly.azurewebsites.net"]
  }
}
